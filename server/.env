# Server Environment Variables
# Copy this file to .env and fill in your values

# Server port
PORT=5001

# MongoDB connection string
# Local: mongodb://localhost:27017/lumira
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/lumira
MONGODB_URI=mongodb://localhost:27017/lumira

# JWT secret for token generation (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:1.5b

# Frontend URL for CORS (adjust for your setup)
FRONTEND_URL=http://localhost:8080